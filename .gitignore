.env.local
.env.development
.env.production
.env.test
**/.env
**/.env.local

# Dependencies
node_modules/
venv/
env/
ENV/
__pycache__/

# Build outputs
dist/
build/
*.egg-info/
.expo/
web-build/

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# OS files
Thumbs.db
.DS_Store

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
.pytest_cache/
.coverage

# Temporary files
*.tmp
temp/
tmp/

# Compiled files
*.pyc
*.pyo
*.pyd
.Python

# Database
*.db
*.sqlite
*.sqlite3

# Large files
UI_Placeholder/metadata.json
UI_Placeholder/node_modules/
UI_Placeholder/dist/

# Build artifacts and cache
*.lock
package-lock.json